{"surah":88,"ayahs":{"1":[{"p":1,"a":"هَلْ","t":"Has","tr":"hal"},{"p":2,"a":"أَتَىٰكَ","t":"(there) come to you","tr":"atāka"},{"p":3,"a":"حَدِيثُ","t":"(the) news","tr":"ḥadīthu"},{"p":4,"a":"ٱلْغَـٰشِيَةِ","t":"(of) the Overwhelming","tr":"l-ghāshiyati"}],"2":[{"p":1,"a":"وُجُوهٌۭ","t":"Faces","tr":"wujūhun"},{"p":2,"a":"يَوْمَئِذٍ","t":"that Day","tr":"yawma-idhin"},{"p":3,"a":"خَـٰشِعَةٌ","t":"(will be) humbled","tr":"khāshiʿatun"}],"3":[{"p":1,"a":"عَامِلَةٌۭ","t":"Laboring","tr":"ʿāmilatun"},{"p":2,"a":"نَّاصِبَةٌۭ","t":"exhausted","tr":"nāṣibatun"}],"4":[{"p":1,"a":"تَصْلَىٰ","t":"They will burn","tr":"taṣlā"},{"p":2,"a":"نَارًا","t":"(in) a Fire","tr":"nāran"},{"p":3,"a":"حَامِيَةًۭ","t":"intensely hot","tr":"ḥāmiyatan"}],"5":[{"p":1,"a":"تُسْقَىٰ","t":"They will be given to drink","tr":"tus'qā"},{"p":2,"a":"مِنْ","t":"from","tr":"min"},{"p":3,"a":"عَيْنٍ","t":"a spring","tr":"ʿaynin"},{"p":4,"a":"ءَانِيَةٍۢ","t":"boiling","tr":"āniyatin"}],"6":[{"p":1,"a":"لَّيْسَ","t":"Not is","tr":"laysa"},{"p":2,"a":"لَهُمْ","t":"for them","tr":"lahum"},{"p":3,"a":"طَعَامٌ","t":"food","tr":"ṭaʿāmun"},{"p":4,"a":"إِلَّا","t":"except","tr":"illā"},{"p":5,"a":"مِن","t":"from","tr":"min"},{"p":6,"a":"ضَرِيعٍۢ","t":"a bitter thorny plant","tr":"ḍarīʿin"}],"7":[{"p":1,"a":"لَّا","t":"Not","tr":"lā"},{"p":2,"a":"يُسْمِنُ","t":"it nourishes","tr":"yus'minu"},{"p":3,"a":"وَلَا","t":"and not","tr":"walā"},{"p":4,"a":"يُغْنِى","t":"it avails","tr":"yugh'nī"},{"p":5,"a":"مِن","t":"from","tr":"min"},{"p":6,"a":"جُوعٍۢ","t":"hunger","tr":"jūʿin"}],"8":[{"p":1,"a":"وُجُوهٌۭ","t":"Faces","tr":"wujūhun"},{"p":2,"a":"يَوْمَئِذٍۢ","t":"that Day","tr":"yawma-idhin"},{"p":3,"a":"نَّاعِمَةٌۭ","t":"(will be) joyful","tr":"nāʿimatun"}],"9":[{"p":1,"a":"لِّسَعْيِهَا","t":"With their effort","tr":"lisaʿyihā"},{"p":2,"a":"رَاضِيَةٌۭ","t":"satisfied","tr":"rāḍiyatun"}],"10":[{"p":1,"a":"فِى","t":"In","tr":"fī"},{"p":2,"a":"جَنَّةٍ","t":"a garden","tr":"jannatin"},{"p":3,"a":"عَالِيَةٍۢ","t":"eleva