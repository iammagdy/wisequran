":"So remind","tr":"fadhakkir"},{"p":2,"a":"إِنَّمَآ","t":"only","tr":"innamā"},{"p":3,"a":"أَنتَ","t":"you","tr":"anta"},{"p":4,"a":"مُذَكِّرٌۭ","t":"(are) a reminder","tr":"mudhakkirun"}],"22":[{"p":1,"a":"لَّسْتَ","t":"You are not","tr":"lasta"},{"p":2,"a":"عَلَيْهِم","t":"over them","tr":"ʿalayhim"},{"p":3,"a":"بِمُصَيْطِرٍ","t":"a controller","tr":"bimuṣayṭirin"}],"23":[{"p":1,"a":"إِلَّا","t":"But","tr":"illā"},{"p":2,"a":"مَن","t":"whoever","tr":"man"},{"p":3,"a":"تَوَلَّىٰ","t":"turns away","tr":"tawallā"},{"p":4,"a":"وَكَفَرَ","t":"and disbelieves","tr":"wakafara"}],"24":[{"p":1,"a":"فَيُعَذِّبُهُ","t":"Then will punish him","tr":"fayuʿadhibuhu"},{"p":2,"a":"ٱللَّهُ","t":"Allah","tr":"l-lahu"},{"p":3,"a":"ٱلْعَذَابَ","t":"(with) the punishment","tr":"l-ʿadhāba"},{"p":4,"a":"ٱلْأَكْبَرَ","t":"greatest","tr":"l-akbara"}],"25":[{"p":1,"a":"إِنَّ","t":"Indeed","tr":"inna"},{"p":2,"a":"إِلَيْنَآ","t":"to Us","tr":"ilaynā"},{"p":3,"a":"إِيَابَهُمْ","t":"(will be) their return","tr":"iyābahum"}],"26":[{"p":1,"a":"ثُمَّ","t":"Then","tr":"thumma"},{"p":2,"a":"إِنَّ","t":"indeed","tr":"inna"},{"p":3,"a":"عَلَيْنَا","t":"upon Us","tr":"ʿalaynā"},{"p":4,"a":"حِسَابَهُم","t":"(is) their account","tr":"ḥisābahum"}]}}