r":"l-dīni"}],"19":[{"p":1,"a":"يَوْمَ","t":"(The) Day","tr":"yawma"},{"p":2,"a":"لَا","t":"not","tr":"lā"},{"p":3,"a":"تَمْلِكُ","t":"will have power","tr":"tamliku"},{"p":4,"a":"نَفْسٌۭ","t":"a soul","tr":"nafsun"},{"p":5,"a":"لِّنَفْسٍۢ","t":"for a soul","tr":"linafsin"},{"p":6,"a":"شَيْـًۭٔا ۖ","t":"anything","tr":"shayan"},{"p":7,"a":"وَٱلْأَمْرُ","t":"and the Command","tr":"wal-amru"},{"p":8,"a":"يَوْمَئِذٍۢ","t":"that Day","tr":"yawma-idhin"},{"p":9,"a":"لِّلَّهِ","t":"(will be) with Allah","tr":"lillahi"}]}}