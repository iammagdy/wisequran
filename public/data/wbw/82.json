{"surah":82,"ayahs":{"1":[{"p":1,"a":"إِذَا","t":"When","tr":"idhā"},{"p":2,"a":"ٱلسَّمَآءُ","t":"the sky","tr":"l-samāu"},{"p":3,"a":"ٱنفَطَرَتْ","t":"(is) cleft asunder","tr":"infaṭarat"}],"2":[{"p":1,"a":"وَإِذَا","t":"And when","tr":"wa-idhā"},{"p":2,"a":"ٱلْكَوَاكِبُ","t":"the stars","tr":"l-kawākibu"},{"p":3,"a":"ٱنتَثَرَتْ","t":"scatter","tr":"intatharat"}],"3":[{"p":1,"a":"وَإِذَا","t":"And when","tr":"wa-idhā"},{"p":2,"a":"ٱلْبِحَارُ","t":"the seas","tr":"l-biḥāru"},{"p":3,"a":"فُجِّرَتْ","t":"are made to gush forth","tr":"fujjirat"}],"4":[{"p":1,"a":"وَإِذَا","t":"And when","tr":"wa-idhā"},{"p":2,"a":"ٱلْقُبُورُ","t":"the graves","tr":"l-qubūru"},{"p":3,"a":"بُعْثِرَتْ","t":"are overturned","tr":"buʿ'thirat"}],"5":[{"p":1,"a":"عَلِمَتْ","t":"Will know","tr":"ʿalimat"},{"p":2,"a":"نَفْسٌۭ","t":"a soul","tr":"nafsun"},{"p":3,"a":"مَّا","t":"what","tr":"mā"},{"p":4,"a":"قَدَّمَتْ","t":"it has sent forth","tr":"qaddamat"},{"p":5,"a":"وَأَخَّرَتْ","t":"and left behind","tr":"wa-akharat"}],"6":[{"p":1,"a":"يَـٰٓأَيُّهَا","t":"O","tr":"yāayyuhā"},{"p":2,"a":"ٱلْإِنسَـٰنُ","t":"man","tr":"l-insānu"},{"p":3,"a":"مَا","t":"What","tr":"mā"},{"p":4,"a":"غَرَّكَ","t":"has deceived you","tr":"gharraka"},{"p":5,"a":"بِرَبِّكَ","t":"concerning your Lord","tr":"birabbika"},{"p":6,"a":"ٱلْكَرِيمِ","t":"the Most Noble","tr":"l-karīmi"}],"7":[{"p":1,"a":"ٱلَّذِى","t":"Who","tr":"alladhī"},{"p":2,"a":"خَلَقَكَ","t":"created you","tr":"khalaqaka"},{"p":3,"a":"فَسَوَّىٰكَ","t":"then fashioned you","tr":"fasawwāka"},{"p":4,"a":"فَعَدَلَكَ","t":"then balanced you","tr":"faʿadalaka"}],"8":[{"p":1,"a":"فِىٓ","t":"In","tr":"fī"},{"p":2,"a":"أَىِّ","t":"whatever","tr":"ayyi"},{"p":3,"a":"صُورَةٍۢ","t":"form","tr":"ṣūratin"},{"p":4,"a":"مَّا","t":"what","tr":"mā"},{"p":5,"a":"شَآءَ","t":"He willed","tr":"shāa"},{"p":6,"a":"رَكَّبَكَ","t":"He assembled you","tr":"rakkabaka"}],"9":[{"p":1,"a":"كَلَّا","t":"Nay","tr":"kallā"},{"p":2,"a":"بَلْ","t":"But","tr":"bal"},{"p":3,"a":"تُكَذِّبُو