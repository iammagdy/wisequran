{"surah":107,"ayahs":{"1":[{"p":1,"a":"أَرَءَيْتَ","t":"Have you seen","tr":"ara-ayta"},{"p":2,"a":"ٱلَّذِى","t":"the one who","tr":"alladhī"},{"p":3,"a":"يُكَذِّبُ","t":"denies","tr":"yukadhibu"},{"p":4,"a":"بِٱلدِّينِ","t":"the Judgment","tr":"bil-dīni"}],"2":[{"p":1,"a":"فَذَٰلِكَ","t":"Then that","tr":"fadhālika"},{"p":2,"a":"ٱلَّذِى","t":"(is) the one who","tr":"alladhī"},{"p":3,"a":"يَدُعُّ","t":"repulses","tr":"yaduʿʿu"},{"p":4,"a":"ٱلْيَتِيمَ","t":"the orphan","tr":"l-yatīma"}],"3":[{"p":1,"a":"وَلَا","t":"And (does) not","tr":"walā"},{"p":2,"a":"يَحُضُّ","t":"feel the urge","tr":"yaḥuḍḍu"},{"p":3,"a":"عَلَىٰ","t":"to","tr":"ʿalā"},{"p":4,"a":"طَعَامِ","t":"feed","tr":"ṭaʿāmi"},{"p":5,"a":"ٱلْمِسْكِينِ","t":"the poor","tr":"l-mis'kīni"}],"4":[{"p":1,"a":"فَوَيْلٌۭ","t":"So woe","tr":"fawaylun"},{"p":2,"a":"لِّلْمُصَلِّينَ","t":"to those who pray","tr":"lil'muṣallīna"}],"5":[{"p":1,"a":"ٱلَّذِينَ","t":"Those who","tr":"alladhīna"},{"p":2,"a":"هُمْ","t":"[they]","tr":"hum"},{"p":3,"a":"عَن","t":"about","tr":"ʿan"},{"p":4,"a":"صَلَاتِهِمْ","t":"their prayers","tr":"ṣalātihim"},{"p":5,"a":"سَاهُونَ","t":"(are) neglectful","tr":"sāhūna"}],"6":[{"p":1,"a":"ٱلَّذِينَ","t":"Those who","tr":"alladhīna"},{"p":2,"a":"هُمْ","t":"[they]","tr":"hum"},{"p":3,"a":"يُرَآءُونَ","t":"make show","tr":"yurāūna"}],"7":[{"p":1,"a":"وَيَمْنَعُونَ","t":"And they deny","tr":"wayamnaʿūna"},{"p":2,"a":"ٱلْمَاعُونَ","t":"[the] small kindnesses","tr":"l-māʿūna"}]}}