{"surah":1,"ayahs":{"1":[{"p":1,"a":"بِسْمِ","t":"In (the) name","tr":"bis'mi"},{"p":2,"a":"ٱللَّهِ","t":"(of) Allah","tr":"l-lahi"},{"p":3,"a":"ٱلرَّحْمَـٰنِ","t":"the Most Gracious","tr":"l-raḥmāni"},{"p":4,"a":"ٱلرَّحِيمِ","t":"the Most Merciful","tr":"l-raḥīmi"}],"2":[{"p":1,"a":"ٱلْحَمْدُ","t":"All praises and thanks","tr":"al-ḥamdu"},{"p":2,"a":"لِلَّهِ","t":"(be) to Allah","tr":"lillahi"},{"p":3,"a":"رَبِّ","t":"the Lord","tr":"rabbi"},{"p":4,"a":"ٱلْعَـٰلَمِينَ","t":"of the universe","tr":"l-ʿālamīna"}],"3":[{"p":1,"a":"ٱلرَّحْمَـٰنِ","t":"The Most Gracious","tr":"al-raḥmāni"},{"p":2,"a":"ٱلرَّحِيمِ","t":"the Most Merciful","tr":"l-raḥīmi"}],"4":[{"p":1,"a":"مَـٰلِكِ","t":"(The) Master","tr":"māliki"},{"p":2,"a":"يَوْمِ","t":"(of the) Day","tr":"yawmi"},{"p":3,"a":"ٱلدِّينِ","t":"(of the) Judgment","tr":"l-dīni"}],"5":[{"p":1,"a":"إِيَّاكَ","t":"You Alone","tr":"iyyāka"},{"p":2,"a":"نَعْبُدُ","t":"we worship","tr":"naʿbudu"},{"p":3,"a":"وَإِيَّاكَ","t":"and You Alone","tr":"wa-iyyāka"},{"p":4,"a":"نَسْتَعِينُ","t":"we ask for help","tr":"nastaʿīnu"}],"6":[{"p":1,"a":"ٱهْدِنَا","t":"Guide us","tr":"ih'dinā"},{"p":2,"a":"ٱلصِّرَٰطَ","t":"(to) the path","tr":"l-ṣirāṭa"},{"p":3,"a":"ٱلْمُسْتَقِيمَ","t":"the straight","tr":"l-mus'taqīma"}],"7":[{"p":1,"a":"صِرَٰطَ","t":"(The) path","tr":"ṣirāṭa"},{"p":2,"a":"ٱلَّذِينَ","t":"(of) those","tr":"alladhīna"},{"p":3,"a":"أَنْعَمْتَ","t":"You have bestowed (Your) Favors","tr":"anʿamta"},{"p":4,"a":"عَلَيْهِمْ","t":"on them","tr":"ʿalayhim"},{"p":5,"a":"غَيْرِ","t":"not (of)","tr":"ghayri"},{"p":6,"a":"ٱلْمَغْضُوبِ","t":"those who earned (Your) wrath","tr":"l-maghḍūbi"},{"p":7,"a":"عَلَيْهِمْ","t":"on themselves","tr":"ʿalayhim"},{"p":8,"a":"وَلَا","t":"and not","tr":"walā"},{"p":9,"a":"ٱلضَّآلِّينَ","t":"(of) those who go astray","tr":"l-ḍālīna"}]}}