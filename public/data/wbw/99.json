{"surah":99,"ayahs":{"1":[{"p":1,"a":"إِذَا","t":"When","tr":"idhā"},{"p":2,"a":"زُلْزِلَتِ","t":"is shaken","tr":"zul'zilati"},{"p":3,"a":"ٱلْأَرْضُ","t":"the earth","tr":"l-arḍu"},{"p":4,"a":"زِلْزَالَهَا","t":"(with) its earthquake","tr":"zil'zālahā"}],"2":[{"p":1,"a":"وَأَخْرَجَتِ","t":"And brings forth","tr":"wa-akhrajati"},{"p":2,"a":"ٱلْأَرْضُ","t":"the earth","tr":"l-arḍu"},{"p":3,"a":"أَثْقَالَهَا","t":"its burdens","tr":"athqālahā"}],"3":[{"p":1,"a":"وَقَالَ","t":"And says","tr":"waqāla"},{"p":2,"a":"ٱلْإِنسَـٰنُ","t":"man","tr":"l-insānu"},{"p":3,"a":"مَا","t":"What","tr":"mā"},{"p":4,"a":"لَهَا","t":"(is) with it","tr":"lahā"}],"4":[{"p":1,"a":"يَوْمَئِذٍۢ","t":"That Day","tr":"yawma-idhin"},{"p":2,"a":"تُحَدِّثُ","t":"it will report","tr":"tuḥaddithu"},{"p":3,"a":"أَخْبَارَهَا","t":"its news","tr":"akhbārahā"}],"5":[{"p":1,"a":"بِأَنَّ","t":"Because","tr":"bi-anna"},{"p":2,"a":"رَبَّكَ","t":"your Lord","tr":"rabbaka"},{"p":3,"a":"أَوْحَىٰ","t":"inspired","tr":"awḥā"},{"p":4,"a":"لَهَا","t":"[to] it","tr":"lahā"}],"6":[{"p":1,"a":"يَوْمَئِذٍۢ","t":"That Day","tr":"yawma-idhin"},{"p":2,"a":"يَصْدُرُ","t":"will proceed","tr":"yaṣduru"},{"p":3,"a":"ٱلنَّاسُ","t":"the mankind","tr":"l-nāsu"},{"p":4,"a":"أَشْتَاتًۭا","t":"(in) scattered groups","tr":"ashtātan"},{"p":5,"a":"لِّيُرَوْا۟","t":"to be shown","tr":"liyuraw"},{"p":6,"a":"أَعْمَـٰلَهُمْ","t":"their deeds","tr":"aʿmālahum"}],"7":[{"p":1,"a":"فَمَن","t":"So whoever","tr":"faman"},{"p":2,"a":"يَعْمَلْ","t":"does","tr":"yaʿmal"},{"p":3,"a":"مِثْقَالَ","t":"(equal to the) weight","tr":"mith'qāla"},{"p":4,"a":"ذَرَّةٍ","t":"(of) an atom","tr":"dharratin"},{"p":5,"a":"خَيْرًۭا","t":"good","tr":"khayran"},{"p":6,"a":"يَرَهُۥ","t":"will see it","tr":"yarahu"}],"8":[{"p":1,"a":"وَمَن","t":"And whoever","tr":"waman"},{"p":2,"a":"يَعْمَلْ","t":"does","tr":"yaʿmal"},{"p":3,"a":"مِثْقَالَ","t":"(equal to the) weight","tr":"mith'qāla"},{"p":4,"a":"ذَرَّةٍۢ","t":"(of) an atom","tr":"dharratin"},{"p":5,"a":"شَرًّۭا","t":"evil","tr":"sharran"},{"p":6,"a":"يَرَهُۥ","t":"will see it","tr":"yarahu"}]}}