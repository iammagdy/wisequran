{"surah":106,"ayahs":{"1":[{"p":1,"a":"لِإِيلَـٰفِ","t":"For (the) familiarity","tr":"liīlāfi"},{"p":2,"a":"قُرَيْشٍ","t":"(of the) Quraish","tr":"qurayshin"}],"2":[{"p":1,"a":"إِۦلَـٰفِهِمْ","t":"Their familiarity","tr":"īlāfihim"},{"p":2,"a":"رِحْلَةَ","t":"(with the) journey","tr":"riḥ'lata"},{"p":3,"a":"ٱلشِّتَآءِ","t":"(of) winter","tr":"l-shitāi"},{"p":4,"a":"وَٱلصَّيْفِ","t":"and summer","tr":"wal-ṣayfi"}],"3":[{"p":1,"a":"فَلْيَعْبُدُوا۟","t":"So let them worship","tr":"falyaʿbudū"},{"p":2,"a":"رَبَّ","t":"(the) Lord","tr":"rabba"},{"p":3,"a":"هَـٰذَا","t":"(of) this","tr":"hādhā"},{"p":4,"a":"ٱلْبَيْتِ","t":"House","tr":"l-bayti"}],"4":[{"p":1,"a":"ٱلَّذِىٓ","t":"The One Who","tr":"alladhī"},{"p":2,"a":"أَطْعَمَهُم","t":"feeds them","tr":"aṭʿamahum"},{"p":3,"a":"مِّن","t":"[from]","tr":"min"},{"p":4,"a":"جُوعٍۢ","t":"(against) hunger","tr":"jūʿin"},{"p":5,"a":"وَءَامَنَهُم","t":"and gives them security","tr":"waāmanahum"},{"p":6,"a":"مِّنْ","t":"from","tr":"min"},{"p":7,"a":"خَوْفٍۭ","t":"fear","tr":"khawfin"}]}}