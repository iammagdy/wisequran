{"surah":84,"ayahs":{"1":[{"p":1,"a":"إِذَا","t":"When","tr":"idhā"},{"p":2,"a":"ٱلسَّمَآءُ","t":"the sky","tr":"l-samāu"},{"p":3,"a":"ٱنشَقَّتْ","t":"is split asunder","tr":"inshaqqat"}],"2":[{"p":1,"a":"وَأَذِنَتْ","t":"And has listened","tr":"wa-adhinat"},{"p":2,"a":"لِرَبِّهَا","t":"to its Lord","tr":"lirabbihā"},{"p":3,"a":"وَحُقَّتْ","t":"and was obligated","tr":"waḥuqqat"}],"3":[{"p":1,"a":"وَإِذَا","t":"And when","tr":"wa-idhā"},{"p":2,"a":"ٱلْأَرْضُ","t":"the earth","tr":"l-arḍu"},{"p":3,"a":"مُدَّتْ","t":"is spread","tr":"muddat"}],"4":[{"p":1,"a":"وَأَلْقَتْ","t":"And has cast out","tr":"wa-alqat"},{"p":2,"a":"مَا","t":"what","tr":"mā"},{"p":3,"a":"فِيهَا","t":"(is) in it","tr":"fīhā"},{"p":4,"a":"وَتَخَلَّتْ","t":"and becomes empty","tr":"watakhallat"}],"5":[{"p":1,"a":"وَأَذِنَتْ","t":"And has listened","tr":"wa-adhinat"},{"p":2,"a":"لِرَبِّهَا","t":"to its Lord","tr":"lirabbihā"},{"p":3,"a":"وَحُقَّتْ","t":"and was obligated","tr":"waḥuqqat"}],"6":[{"p":1,"a":"يَـٰٓأَيُّهَا","t":"O","tr":"yāayyuhā"},{"p":2,"a":"ٱلْإِنسَـٰنُ","t":"mankind","tr":"l-insānu"},{"p":3,"a":"إِنَّكَ","t":"Indeed, you","tr":"innaka"},{"p":4,"a":"كَادِحٌ","t":"(are) laboring","tr":"kādiḥun"},{"p":5,"a":"إِلَىٰ","t":"to","tr":"ilā"},{"p":6,"a":"رَبِّكَ","t":"your Lord","tr":"rabbika"},{"p":7,"a":"كَدْحًۭا","t":"(with) exertion","tr":"kadḥan"},{"p":8,"a":"فَمُلَـٰقِيهِ","t":"and you (will) meet Him","tr":"famulāqīhi"}],"7":[{"p":1,"a":"فَأَمَّا","t":"Then as for","tr":"fa-ammā"},{"p":2,"a":"مَنْ","t":"(him) who","tr":"man"},{"p":3,"a":"أُوتِىَ","t":"is given","tr":"ūtiya"},{"p":4,"a":"كِتَـٰبَهُۥ","t":"his record","tr":"kitābahu"},{"p":5,"a":"بِيَمِينِهِۦ","t":"in his right (hand)","tr":"biyamīnihi"}],"8":[{"p":1,"a":"فَسَوْفَ","t":"Then soon","tr":"fasawfa"},{"p":2,"a":"يُحَاسَبُ","t":"his account will be taken","tr":"yuḥāsabu"},{"p":3,"a":"حِسَابًۭا","t":"an account","tr":"ḥisāban"},{"p":4,"a":"يَسِيرًۭا","t":"easy","tr":"yasīran"}],"9":[{"p":1,"a":"وَيَنقَلِبُ","t":"And he will return","tr":"wayanqalibu"},{"p":2,"a":"إِلَىٰٓ","t":"to","tr":"ilā"},{"p":3,"a":"أَهْلِهِۦ","t":"his people","tr":"ahlihi"},{"p":4,"a":"مَسْرُورًۭا","t":"happily","tr":"masrūran"}],"10":[{"p":1,"a":"وَأَمَّا","t":"But as for","tr":"wa-ammā"},{"p":2,"a":"مَنْ","t":"(him) who","tr":"man"},{"p":3,"a":"أُوتِىَ","t":"is given","tr":"ūtiya"},{"p":4,"a":"كِتَـٰبَهُۥ","t":"his record","tr":"kitābahu"},{"p":5,"a":"وَرَآءَ","t":"behind","tr":"warāa"},{"p":6,"a":"ظَهْرِهِۦ","t":"his back","tr":"ẓahrihi"}],"11":[{"p":1,"a":"فَسَوْفَ","t":"Then soon","tr":"fasawfa"},{"p":2,"a":"يَدْعُوا۟","t":"he will call","tr":"yadʿū"},{"p":3,"a":"ثُبُورًۭا","t":"(for) destruction","tr":"thubūran"}],"12":[{"p":1,"a":"وَيَصْلَىٰ","t":"And he will burn","tr":"wayaṣlā"},{"p":2,"a":"سَعِيرًا","t":"(in) a Blaze","tr":"saʿīran"}],"13":[{"p":1,"a":"إِنَّهُۥ","t":"Indeed, he","tr":"innahu"},{"p":2,"a":"كَانَ","t":"had been","tr":"kāna"},{"p":3,"a":"فِىٓ","t":"among","tr":"fī"},{"p":4,"a":"أَهْلِهِۦ","t":"his people","tr":"ahlihi"},{"p":5,"a":"مَسْرُورًا","t":"happy","tr":"masrūran"}],"14":[{"p":1,"a":"إِنَّهُۥ","t":"Indeed, he","tr":"innahu"},{"p":2,"a":"ظَنَّ","t":"(had) thought","tr":"ẓanna"},{"p":3,"a":"أَن","t":"that","tr":"an"},{"p":4,"a":"لَّن","t":"never","tr":"lan"},{"p":5,"a":"يَحُورَ","t":"he would return","tr":"yaḥūra"}],"15":[{"p":1,"a":"بَلَىٰٓ","t":"Yes","tr":"balā"},{"p":2,"a":"إِنَّ","t":"Indeed","tr":"inna"},{"p":3,"a":"رَبَّهُۥ","t":"his Lord","tr":"rabbahu"},{"p":4,"a":"كَانَ","t":"was","tr":"kāna"},{"p":5,"a":"بِهِۦ","t":"of him","tr":"bihi"},{"p":6,"a":"بَصِيرًۭا","t":"All-Seer","tr":"baṣīran"}],"16":[{"p":1,"a":"فَلَآ","t":"But nay","tr":"falā"},{"p":2,"a":"أُقْسِمُ","t":"I swear","tr":"uq'simu"},{"p":3,"a":"بِٱلشَّفَقِ","t":"by the twilight glow","tr":"bil-shafaqi"}],"17":[{"p":1,"a":"وَٱلَّيْلِ","t":"And the night","tr":"wa-al-layli"},{"p":2,"a":"وَمَا","t":"and what","tr":"wamā"},{"p":3,"a":"وَسَقَ","t":"it envelops","tr":"wasaqa"}],"18":[{"p":1,"a":"وَٱلْقَمَرِ","t":"And