{"surah":100,"ayahs":{"1":[{"p":1,"a":"وَٱلْعَـٰدِيَـٰتِ","t":"By the racers","tr":"wal-ʿādiyāti"},{"p":2,"a":"ضَبْحًۭا","t":"panting","tr":"ḍabḥan"}],"2":[{"p":1,"a":"فَٱلْمُورِيَـٰتِ","t":"And the producers of sparks","tr":"fal-mūriyāti"},{"p":2,"a":"قَدْحًۭا","t":"striking","tr":"qadḥan"}],"3":[{"p":1,"a":"فَٱلْمُغِيرَٰتِ","t":"And the chargers","tr":"fal-mughīrāti"},{"p":2,"a":"صُبْحًۭا","t":"(at) dawn","tr":"ṣub'ḥan"}],"4":[{"p":1,"a":"فَأَثَرْنَ","t":"Then raise","tr":"fa-atharna"},{"p":2,"a":"بِهِۦ","t":"thereby","tr":"bihi"},{"p":3,"a":"نَقْعًۭا","t":"dust","tr":"naqʿan"}],"5":[{"p":1,"a":"فَوَسَطْنَ","t":"Then penetrate (in the) center","tr":"fawasaṭna"},{"p":2,"a":"بِهِۦ","t":"thereby","tr":"bihi"},{"p":3,"a":"جَمْعًا","t":"collectively","tr":"jamʿan"}],"6":[{"p":1,"a":"إِنَّ","t":"Indeed","tr":"inna"},{"p":2,"a":"ٱلْإِنسَـٰنَ","t":"mankind","tr":"l-insāna"},{"p":3,"a":"لِرَبِّهِۦ","t":"to his Lord","tr":"lirabbihi"},{"p":4,"a":"لَكَنُودٌۭ","t":"(is) surely ungrateful","tr":"lakanūdun"}],"7":[{"p":1,"a":"وَإِنَّهُۥ","t":"And indeed, he","tr":"wa-innahu"},{"p":2,"a":"عَلَىٰ","t":"on","tr":"ʿalā"},{"p":3,"a":"ذَٰلِكَ","t":"that","tr":"dhālika"},{"p":4,"a":"لَشَهِيدٌۭ","t":"surely (is) a witness","tr":"lashahīdun"}],"8":[{"p":1,"a":"وَإِنَّهُۥ","t":"And indeed he","tr":"wa-innahu"},{"p":2,"a":"لِحُبِّ","t":"in (the) love","tr":"liḥubbi"},{"p":3,"a":"ٱلْخَيْرِ","t":"(of) wealth","tr":"l-khayri"},{"p":4,"a":"لَشَدِيدٌ","t":"(is) surely intense","tr":"lashadīdun"}],"9":[{"p":1,"a":"۞ أَفَلَا","t":"But does not","tr":"afalā"},{"p":2,"a":"يَعْلَمُ","t":"he know","tr":"yaʿlamu"},{"p":3,"a":"إِذَا","t":"when","tr":"idhā"},{"p":4,"a":"بُعْثِرَ","t":"will be scattered","tr":"buʿ'thira"},{"p":5,"a":"مَا","t":"what","tr":"mā"},{"p":6,"a":"فِى","t":"(is) in","tr":"fī"},{"p":7,"a":"ٱلْقُبُورِ","t":"the graves","tr":"l-qubūri"}],"10":[{"p":1,"a":"وَحُصِّلَ","t":"And is made apparent","tr":"waḥuṣṣila"},{"p":2,"a":"مَا","t":"what","tr":"mā"},{"p":3,"a":"فِى","t":"(is) in","t