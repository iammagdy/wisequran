{"surah":91,"ayahs":{"1":[{"p":1,"a":"وَٱلشَّمْسِ","t":"By the sun","tr":"wal-shamsi"},{"p":2,"a":"وَضُحَىٰهَا","t":"and its brightness","tr":"waḍuḥāhā"}],"2":[{"p":1,"a":"وَٱلْقَمَرِ","t":"And the moon","tr":"wal-qamari"},{"p":2,"a":"إِذَا","t":"when","tr":"idhā"},{"p":3,"a":"تَلَىٰهَا","t":"it follows it","tr":"talāhā"}],"3":[{"p":1,"a":"وَٱلنَّهَارِ","t":"And the day","tr":"wal-nahāri"},{"p":2,"a":"إِذَا","t":"when","tr":"idhā"},{"p":3,"a":"جَلَّىٰهَا","t":"it displays it","tr":"jallāhā"}],"4":[{"p":1,"a":"وَٱلَّيْلِ","t":"And the night","tr":"wa-al-layli"},{"p":2,"a":"إِذَا","t":"when","tr":"idhā"},{"p":3,"a":"يَغْشَىٰهَا","t":"it covers it","tr":"yaghshāhā"}],"5":[{"p":1,"a":"وَٱلسَّمَآءِ","t":"And the heaven","tr":"wal-samāi"},{"p":2,"a":"وَمَا","t":"and (He) Who","tr":"wamā"},{"p":3,"a":"بَنَىٰهَا","t":"constructed it","tr":"banāhā"}],"6":[{"p":1,"a":"وَٱلْأَرْضِ","t":"And the earth","tr":"wal-arḍi"},{"p":2,"a":"وَمَا","t":"and by (He) Who","tr":"wamā"},{"p":3,"a":"طَحَىٰهَا","t":"spread it","tr":"ṭaḥāhā"}],"7":[{"p":1,"a":"وَنَفْسٍۢ","t":"And (the) soul","tr":"wanafsin"},{"p":2,"a":"وَمَا","t":"and (He) Who","tr":"wamā"},{"p":3,"a":"سَوَّىٰهَا","t":"proportioned it","tr":"sawwāhā"}],"8":[{"p":1,"a":"فَأَلْهَمَهَا","t":"And He inspired it","tr":"fa-alhamahā"},{"p":2,"a":"فُجُورَهَا","t":"(to distinguish) its wickedness","tr":"fujūrahā"},{"p":3,"a":"وَتَقْوَىٰهَا","t":"and its righteousness","tr":"wataqwāhā"}],"9":[{"p":1,"a":"قَدْ","t":"Indeed","tr":"qad"},{"p":2,"a":"أَفْلَحَ","t":"he succeeds","tr":"aflaḥa"},{"p":3,"a":"مَن","t":"who","tr":"man"},{"p":4,"a":"زَكَّىٰهَا","t":"purifies it","tr":"zakkāhā"}],"10":[{"p":1,"a":"وَقَدْ","t":"And indeed","tr":"waqad"},{"p":2,"a":"خَابَ","t":"he fails","tr":"khāba"},{"p":3,"a":"مَن","t":"who","tr":"man"},{"p":4,"a":"دَسَّىٰهَا","t":"buries it","tr":"dassāhā"}],"11":[{"p":1,"a":"كَذَّبَتْ","t":"Denied","tr":"kadhabat"},{"p":2,"a":"ثَمُودُ","t":"Thamud","tr":"thamūdu"},{"p":3,"a":"بِطَغْوَىٰهَآ","t":"by their transgression","tr":"biṭaghwāhā"}],"12":[{"p":1,"a":"إِذِ","t":"When","tr":"idhi"},{"p":2,"a":"ٱنۢبَعَثَ","t":"(was) sent forth","tr":"inbaʿatha"},{"p":3,"a":"أَشْقَىٰهَا","t":"(the) most wicked of them","tr":"ashqāhā"}],"13":[{"p":1,"a":"فَقَالَ","t":"But said","tr":"faqāla"},{"p":2,"a":"لَهُمْ","t":"to them","tr":"lahum"},{"p":3,"a":"رَسُولُ","t":"(the) Messenger","tr":"rasūlu"},{"p":4,"a":"ٱللَّهِ","t":"(of) Allah","tr":"l-lahi"},{"p":5,"a":"نَاقَةَ","t":"(It is the) she-camel","tr":"nāqata"},{"p":6,"a":"ٱللَّهِ","t":"(of) Allah","tr":"l-lahi"},{"p":7,"a":"وَسُقْيَـٰهَا","t":"and her drink","tr":"wasuq'yāhā"}],"14":[{"p":1,"a":"فَكَذَّبُوهُ","t":"But they denied him","tr":"fakadhabūhu"},{"p":2,"a":"فَعَقَرُوهَا","t":"and they hamstrung her","tr":"faʿaqarūhā"},{"p":3,"a":"فَدَمْدَمَ","t":"So destroyed","tr":"fadamdama"},{"p":4,"a":"عَلَيْهِمْ","t":"them","tr":"ʿalayhim"},{"p":5,"a":"رَبُّهُم","t":"their Lord","tr":"rabbuhum"},{"p":6,"a":"بِذَنۢبِهِمْ","t":"for their sin","tr":"bidhanbihim"},{"p":7,"a":"فَسَوَّىٰهَا","t":"and leveled them","tr":"fasawwāhā"}],"15":[{"p":1,"a":"وَلَا","t":"And not","tr":"walā"},{"p":2,"a":"يَخَافُ","t":"He fears","tr":"yakhāfu"},{"p":3,"a":"عُقْبَـٰهَا","t":"its consequences","tr":"ʿuq'bāhā"}]}}