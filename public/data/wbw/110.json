{"surah":110,"ayahs":{"1":[{"p":1,"a":"إِذَا","t":"When","tr":"idhā"},{"p":2,"a":"جَآءَ","t":"comes","tr":"jāa"},{"p":3,"a":"نَصْرُ","t":"(the) Help","tr":"naṣru"},{"p":4,"a":"ٱللَّهِ","t":"(of) Allah","tr":"l-lahi"},{"p":5,"a":"وَٱلْفَتْحُ","t":"and the Victory","tr":"wal-fatḥu"}],"2":[{"p":1,"a":"وَرَأَيْتَ","t":"And you see","tr":"wara-ayta"},{"p":2,"a":"ٱلنَّاسَ","t":"the people","tr":"l-nāsa"},{"p":3,"a":"يَدْخُلُونَ","t":"entering","tr":"yadkhulūna"},{"p":4,"a":"فِى","t":"into","tr":"fī"},{"p":5,"a":"دِينِ","t":"(the) religion","tr":"dīni"},{"p":6,"a":"ٱللَّهِ","t":"(of) Allah","tr":"l-lahi"},{"p":7,"a":"أَفْوَاجًۭا","t":"(in) multitudes","tr":"afwājan"}],"3":[{"p":1,"a":"فَسَبِّحْ","t":"Then glorify","tr":"fasabbiḥ"},{"p":2,"a":"بِحَمْدِ","t":"with (the) praises","tr":"biḥamdi"},{"p":3,"a":"رَبِّكَ","t":"(of) your Lord","tr":"rabbika"},{"p":4,"a":"وَٱسْتَغْفِرْهُ ۚ","t":"and ask His forgiveness","tr":"wa-is'taghfir'hu"},{"p":5,"a":"إِنَّهُۥ","t":"Indeed, He","tr":"innahu"},{"p":6,"a":"كَانَ","t":"is","tr":"kāna"},{"p":7,"a":"تَوَّابًۢا","t":"Oft-Returning","tr":"tawwāban"}]}}