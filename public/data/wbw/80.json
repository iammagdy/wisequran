{"surah":80,"ayahs":{"1":[{"p":1,"a":"عَبَسَ","t":"He frowned","tr":"ʿabasa"},{"p":2,"a":"وَتَوَلَّىٰٓ","t":"and turned away","tr":"watawallā"}],"2":[{"p":1,"a":"أَن","t":"Because","tr":"an"},{"p":2,"a":"جَآءَهُ","t":"came to him","tr":"jāahu"},{"p":3,"a":"ٱلْأَعْمَىٰ","t":"the blind man","tr":"l-aʿmā"}],"3":[{"p":1,"a":"وَمَا","t":"But what","tr":"wamā"},{"p":2,"a":"يُدْرِيكَ","t":"would make you know","tr":"yud'rīka"},{"p":3,"a":"لَعَلَّهُۥ","t":"that he might","tr":"laʿallahu"},{"p":4,"a":"يَزَّكَّىٰٓ","t":"purify himself","tr":"yazzakkā"}],"4":[{"p":1,"a":"أَوْ","t":"Or","tr":"aw"},{"p":2,"a":"يَذَّكَّرُ","t":"be reminded","tr":"yadhakkaru"},{"p":3,"a":"فَتَنفَعَهُ","t":"so would benefit him","tr":"fatanfaʿahu"},{"p":4,"a":"ٱلذِّكْرَىٰٓ","t":"the reminder","tr":"l-dhik'rā"}],"5":[{"p":1,"a":"أَمَّا","t":"As for","tr":"ammā"},{"p":2,"a":"مَنِ","t":"(him) who","tr":"mani"},{"p":3,"a":"ٱسْتَغْنَىٰ","t":"considers himself free from need","tr":"is'taghnā"}],"6":[{"p":1,"a":"فَأَنتَ","t":"So you","tr":"fa-anta"},{"p":2,"a":"لَهُۥ","t":"to him","tr":"lahu"},{"p":3,"a":"تَصَدَّىٰ","t":"give attention","tr":"taṣaddā"}],"7":[{"p":1,"a":"وَمَا","t":"And not","tr":"wamā"},{"p":2,"a":"عَلَيْكَ","t":"upon you","tr":"ʿalayka"},{"p":3,"a":"أَلَّا","t":"that not","tr":"allā"},{"p":4,"a":"يَزَّكَّىٰ","t":"he purifies himself","tr":"yazzakkā"}],"8":[{"p":1,"a":"وَأَمَّا","t":"But as for","tr":"wa-ammā"},{"p":2,"a":"مَن","t":"(he) who","tr":"man"},{"p":3,"a":"جَآءَكَ","t":"came to you","tr":"jāaka"},{"p":4,"a":"يَسْعَىٰ","t":"striving","tr":"yasʿā"}],"9":[{"p":1,"a":"وَهُوَ","t":"While he","tr":"wahuwa"},{"p":2,"a":"يَخْشَىٰ","t":"fears","tr":"yakhshā"}],"10":[{"p":1,"a":"فَأَنتَ","t":"But you","tr":"fa-anta"},{"p":2,"a":"عَنْهُ","t":"from him","tr":"ʿanhu"},{"p":3,"a":"تَلَهَّىٰ","t":"(are) distracted","tr":"talahhā"}],"11":[{"p":1,"a":"كَلَّآ","t":"Nay","tr":"kallā"},{"p":2,"a":"إِنَّهَا","t":"Indeed, it","tr":"innahā"},{"p":3,"a":"تَذْكِرَةٌۭ","t":"(is) a reminder","tr":"tadh