ay","tr":"yawma"},{"p":2,"a":"يَفِرُّ","t":"will flee","tr":"yafirru"},{"p":3,"a":"ٱلْمَرْءُ","t":"a man","tr":"l-maru"},{"p":4,"a":"مِنْ","t":"from","tr":"min"},{"p":5,"a":"أَخِيهِ","t":"his brother","tr":"akhīhi"}],"35":[{"p":1,"a":"وَأُمِّهِۦ","t":"And his mother","tr":"wa-ummihi"},{"p":2,"a":"وَأَبِيهِ","t":"and his father","tr":"wa-abīhi"}],"36":[{"p":1,"a":"وَصَـٰحِبَتِهِۦ","t":"And his wife","tr":"waṣāḥibatihi"},{"p":2,"a":"وَبَنِيهِ","t":"and his children","tr":"wabanīhi"}],"37":[{"p":1,"a":"لِكُلِّ","t":"For every","tr":"likulli"},{"p":2,"a":"ٱمْرِئٍۢ","t":"man","tr":"im'ri-in"},{"p":3,"a":"مِّنْهُمْ","t":"among them","tr":"min'hum"},{"p":4,"a":"يَوْمَئِذٍۢ","t":"that Day","tr":"yawma-idhin"},{"p":5,"a":"شَأْنٌۭ","t":"(will be) a matter","tr":"shanun"},{"p":6,"a":"يُغْنِيهِ","t":"occupying him","tr":"yugh'nīhi"}],"38":[{"p":1,"a":"وُجُوهٌۭ","t":"Faces","tr":"wujūhun"},{"p":2,"a":"يَوْمَئِذٍۢ","t":"that Day","tr":"yawma-idhin"},{"p":3,"a":"مُّسْفِرَةٌۭ","t":"(will be) bright","tr":"mus'firatun"}],"39":[{"p":1,"a":"ضَاحِكَةٌۭ","t":"Laughing","tr":"ḍāḥikatun"},{"p":2,"a":"مُّسْتَبْشِرَةٌۭ","t":"rejoicing at good news","tr":"mus'tabshiratun"}],"40":[{"p":1,"a":"وَوُجُوهٌۭ","t":"And faces","tr":"wawujūhun"},{"p":2,"a":"يَوْمَئِذٍ","t":"that Day","tr":"yawma-idhin"},{"p":3,"a":"عَلَيْهَا","t":"upon them","tr":"ʿalayhā"},{"p":4,"a":"غَبَرَةٌۭ","t":"(will be) dust","tr":"ghabaratun"}],"41":[{"p":1,"a":"تَرْهَقُهَا","t":"Will cover them","tr":"tarhaquhā"},{"p":2,"a":"قَتَرَةٌ","t":"darkness","tr":"qataratun"}],"42":[{"p":1,"a":"أُو۟لَـٰٓئِكَ","t":"Those","tr":"ulāika"},{"p":2,"a":"هُمُ","t":"[they]","tr":"humu"},{"p":3,"a":"ٱلْكَفَرَةُ","t":"(are) the disbelievers","tr":"l-kafaratu"},{"p":4,"a":"ٱلْفَجَرَةُ","t":"the wicked ones","tr":"l-fajaratu"}]}}