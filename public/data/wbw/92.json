{"surah":92,"ayahs":{"1":[{"p":1,"a":"وَٱلَّيْلِ","t":"By the night","tr":"wa-al-layli"},{"p":2,"a":"إِذَا","t":"when","tr":"idhā"},{"p":3,"a":"يَغْشَىٰ","t":"it covers","tr":"yaghshā"}],"2":[{"p":1,"a":"وَٱلنَّهَارِ","t":"And the day","tr":"wal-nahāri"},{"p":2,"a":"إِذَا","t":"when","tr":"idhā"},{"p":3,"a":"تَجَلَّىٰ","t":"it shines in brightness","tr":"tajallā"}],"3":[{"p":1,"a":"وَمَا","t":"And He Who","tr":"wamā"},{"p":2,"a":"خَلَقَ","t":"created","tr":"khalaqa"},{"p":3,"a":"ٱلذَّكَرَ","t":"the male","tr":"l-dhakara"},{"p":4,"a":"وَٱلْأُنثَىٰٓ","t":"and the female","tr":"wal-unthā"}],"4":[{"p":1,"a":"إِنَّ","t":"Indeed","tr":"inna"},{"p":2,"a":"سَعْيَكُمْ","t":"your efforts","tr":"saʿyakum"},{"p":3,"a":"لَشَتَّىٰ","t":"(are) surely diverse","tr":"lashattā"}],"5":[{"p":1,"a":"فَأَمَّا","t":"Then as for","tr":"fa-ammā"},{"p":2,"a":"مَنْ","t":"(him) who","tr":"man"},{"p":3,"a":"أَعْطَىٰ","t":"gives","tr":"aʿṭā"},{"p":4,"a":"وَٱتَّقَىٰ","t":"and fears","tr":"wa-ittaqā"}],"6":[{"p":1,"a":"وَصَدَّقَ","t":"And believes","tr":"waṣaddaqa"},{"p":2,"a":"بِٱلْحُسْنَىٰ","t":"in the best","tr":"bil-ḥus'nā"}],"7":[{"p":1,"a":"فَسَنُيَسِّرُهُۥ","t":"Then We will ease him","tr":"fasanuyassiruhu"},{"p":2,"a":"لِلْيُسْرَىٰ","t":"towards [the] ease","tr":"lil'yus'rā"}],"8":[{"p":1,"a":"وَأَمَّا","t":"But as for","tr":"wa-ammā"},{"p":2,"a":"مَنۢ","t":"(him) who","tr":"man"},{"p":3,"a":"بَخِلَ","t":"withholds","tr":"bakhila"},{"p":4,"a":"وَٱسْتَغْنَىٰ","t":"and considers himself free from need","tr":"wa-is'taghnā"}],"9":[{"p":1,"a":"وَكَذَّبَ","t":"And denies","tr":"wakadhaba"},{"p":2,"a":"بِٱلْحُسْنَىٰ","t":"the best","tr":"bil-ḥus'nā"}],"10":[{"p":1,"a":"فَسَنُيَسِّرُهُۥ","t":"Then We will ease him","tr":"fasanuyassiruhu"},{"p":2,"a":"لِلْعُسْرَىٰ","t":"towards [the] difficulty","tr":"lil'ʿus'rā"}],"11":[{"p":1,"a":"وَمَا","t":"And not","tr":"wamā"},{"p":2,"a":"يُغْنِى","t":"will avail","tr":"yugh'nī"},{"p":3,"a":"عَنْهُ","t":"him","tr":"ʿanhu"},{"p":4,"a":"مَالُهُۥٓ","t":"his wealth","tr":"māluhu"},{"p":5,"a":"إِذَا","t":"when","tr":"idhā"},{"p":6,"a":"تَرَدَّىٰٓ","t":"he falls","tr":"taraddā"}],"12":[{"p":1,"a":"إِنَّ","t":"Indeed","tr":"inna"},{"p":2,"a":"عَلَيْنَا","t":"upon Us","tr":"ʿalaynā"},{"p":3,"a":"لَلْهُدَىٰ","t":"(is) the guidance","tr":"lalhudā"}],"13":[{"p":1,"a":"وَإِنَّ","t":"And indeed","tr":"wa-inna"},{"p":2,"a":"لَنَا","t":"for Us","tr":"lanā"},{"p":3,"a":"لَلْـَٔاخِرَةَ","t":"(is) the Hereafter","tr":"lalākhirata"},{"p":4,"a":"وَٱلْأُولَىٰ","t":"and the first (life)","tr":"wal-ūlā"}],"14":[{"p":1,"a":"فَأَنذَرْتُكُمْ","t":"So I warn you","tr":"fa-andhartukum"},{"p":2,"a":"نَارًۭا","t":"(of) a Fire","tr":"nāran"},{"p":3,"a":"تَلَظَّىٰ","t":"blazing","tr":"talaẓẓā"}],"15":[{"p":1,"a":"لَا","t":"Not","tr":"lā"},{"p":2,"a":"يَصْلَىٰهَآ","t":"will burn (in) it","tr":"yaṣlāhā"},{"p":3,"a":"إِلَّا","t":"except","tr":"illā"},{"p":4,"a":"ٱلْأَشْقَى","t":"the most wretched","tr":"l-ashqā"}],"16":[{"p":1,"a":"ٱلَّذِى","t":"The one who","tr":"alladhī"},{"p":2,"a":"كَذَّبَ","t":"denied","tr":"kadhaba"},{"p":3,"a":"وَتَوَلَّىٰ","t":"and turned away","tr":"watawallā"}],"17":[{"p":1,"a":"وَسَيُجَنَّبُهَا","t":"But will be removed from it","tr":"wasayujannabuhā"},{"p":2,"a":"ٱلْأَتْقَى","t":"the righteous","tr":"l-atqā"}],"18":[{"p":1,"a":"ٱلَّذِى","t":"The one who","tr":"alladhī"},{"p":2,"a":"يُؤْتِى","t":"gives","tr":"yu'tī"},{"p":3,"a":"مَالَهُۥ","t":"his wealth","tr":"mālahu"},{"p":4,"a":"يَتَزَكَّىٰ","t":"(to) purify himself","tr":"yatazakkā"}],"19":[{"p":1,"a":"وَمَا","t":"And not","tr":"wamā"},{"p":2,"a":"لِأَحَدٍ","t":"for anyone","tr":"li-aḥadin"},{"p":3,"a":"عِندَهُۥ","t":"with him","tr":"ʿindahu"},{"p":4,"a":"مِن","t":"any","tr":"min"},{"p":5,"a":"نِّعْمَةٍۢ","t":"favor","tr":"niʿ'matin"},{"p":6,"a":"تُجْزَىٰٓ","t":"to be recompensed","tr":"tuj'zā"}],"20":[{"p":1,"a":"إِلَّا","t":"Except","tr":"illā"},{"p":2,"a":"ٱبْتِغَآءَ","t":"seeking","tr":"ib'tighāa"},{"p":3,"a":"وَجْهِ","t":"(the) Countenance","tr":"wajhi"},{"p":4,"a":"رَبِّهِ","t":"(of) his Lord","tr":"rabbihi"},{"p":5,"a":"ٱلْأَعْلَىٰ","t":"the Most High","tr":"l-aʿlā"}],"21":[{"p":1,"a":"وَلَسَوْفَ","t":"And soon, surely","tr":"walasawfa"},{"p":2,"a":"يَرْضَىٰ","t":"he will be pleased","tr":"yarḍā"}]}}