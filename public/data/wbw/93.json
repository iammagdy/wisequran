{"surah":93,"ayahs":{"1":[{"p":1,"a":"وَٱلضُّحَىٰ","t":"By the morning brightness","tr":"wal-ḍuḥā"}],"2":[{"p":1,"a":"وَٱلَّيْلِ","t":"And the night","tr":"wa-al-layli"},{"p":2,"a":"إِذَا","t":"when","tr":"idhā"},{"p":3,"a":"سَجَىٰ","t":"it covers with darkness","tr":"sajā"}],"3":[{"p":1,"a":"مَا","t":"Not","tr":"mā"},{"p":2,"a":"وَدَّعَكَ","t":"has forsaken you","tr":"waddaʿaka"},{"p":3,"a":"رَبُّكَ","t":"your Lord","tr":"rabbuka"},{"p":4,"a":"وَمَا","t":"and not","tr":"wamā"},{"p":5,"a":"قَلَىٰ","t":"He is displeased","tr":"qalā"}],"4":[{"p":1,"a":"وَلَلْـَٔاخِرَةُ","t":"And surely the Hereafter","tr":"walalākhiratu"},{"p":2,"a":"خَيْرٌۭ","t":"(is) better","tr":"khayrun"},{"p":3,"a":"لَّكَ","t":"for you","tr":"laka"},{"p":4,"a":"مِنَ","t":"than","tr":"mina"},{"p":5,"a":"ٱلْأُولَىٰ","t":"the first","tr":"l-ūlā"}],"5":[{"p":1,"a":"وَلَسَوْفَ","t":"And soon","tr":"walasawfa"},{"p":2,"a":"يُعْطِيكَ","t":"will give you","tr":"yuʿ'ṭīka"},{"p":3,"a":"رَبُّكَ","t":"your Lord","tr":"rabbuka"},{"p":4,"a":"فَتَرْضَىٰٓ","t":"then you will be satisfied","tr":"fatarḍā"}],"6":[{"p":1,"a":"أَلَمْ","t":"Did not","tr":"alam"},{"p":2,"a":"يَجِدْكَ","t":"He find you","tr":"yajid'ka"},{"p":3,"a":"يَتِيمًۭا","t":"an orphan","tr":"yatīman"},{"p":4,"a":"فَـَٔاوَىٰ","t":"and give shelter","tr":"faāwā"}],"7":[{"p":1,"a":"وَوَجَدَكَ","t":"And He found you","tr":"wawajadaka"},{"p":2,"a":"ضَآلًّۭا","t":"lost","tr":"ḍāllan"},{"p":3,"a":"فَهَدَىٰ","t":"so He guided","tr":"fahadā"}],"8":[{"p":1,"a":"وَوَجَدَكَ","t":"And He found you","tr":"wawajadaka"},{"p":2,"a":"عَآئِلًۭا","t":"in need","tr":"ʿāilan"},{"p":3,"a":"فَأَغْنَىٰ","t":"so He made self-sufficient","tr":"fa-aghnā"}],"9":[{"p":1,"a":"فَأَمَّا","t":"So as for","tr":"fa-ammā"},{"p":2,"a":"ٱلْيَتِيمَ","t":"the orphan","tr":"l-yatīma"},{"p":3,"a":"فَلَا","t":"then (do) not","tr":"falā"},{"p":4,"a":"تَقْهَرْ","t":"oppress","tr":"taqhar"}],"10":[{"p":1,"a":"وَأَمَّا","t":"And as for","tr":"wa-ammā"},{"p":2,"a":"ٱلسَّآئِلَ","t":"one who asks","tr":"l-sāila"},{"p":3,"a":"فَلَا","t":"then (do) not","tr":"falā"},{"p":4,"a":"تَنْهَرْ","t":"repel","tr":"tanhar"}],"11":[{"p":1,"a":"وَأَمَّا","t":"But as for","tr":"wa-ammā"},{"p":2,"a":"بِنِعْمَةِ","t":"(the) Favor","tr":"biniʿ'mati"},{"p":3,"a":"رَبِّكَ","t":"(of) your Lord","tr":"rabbika"},{"p":4,"a":"فَحَدِّثْ","t":"narrate","tr":"faḥaddith"}]}}