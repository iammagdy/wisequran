{"surah":79,"ayahs":{"1":[{"p":1,"a":"وَٱلنَّـٰزِعَـٰتِ","t":"By those who extract","tr":"wal-nāziʿāti"},{"p":2,"a":"غَرْقًۭا","t":"violently","tr":"gharqan"}],"2":[{"p":1,"a":"وَٱلنَّـٰشِطَـٰتِ","t":"And those who draw out","tr":"wal-nāshiṭāti"},{"p":2,"a":"نَشْطًۭا","t":"gently","tr":"nashṭan"}],"3":[{"p":1,"a":"وَٱلسَّـٰبِحَـٰتِ","t":"And those who glide","tr":"wal-sābiḥāti"},{"p":2,"a":"سَبْحًۭا","t":"swimming","tr":"sabḥan"}],"4":[{"p":1,"a":"فَٱلسَّـٰبِقَـٰتِ","t":"And those who race each other","tr":"fal-sābiqāti"},{"p":2,"a":"سَبْقًۭا","t":"(in) a race","tr":"sabqan"}],"5":[{"p":1,"a":"فَٱلْمُدَبِّرَٰتِ","t":"And those who arrange","tr":"fal-mudabirāti"},{"p":2,"a":"أَمْرًۭا","t":"(the) matter","tr":"amran"}],"6":[{"p":1,"a":"يَوْمَ","t":"(The) Day","tr":"yawma"},{"p":2,"a":"تَرْجُفُ","t":"will quake","tr":"tarjufu"},{"p":3,"a":"ٱلرَّاجِفَةُ","t":"the quaking one","tr":"l-rājifatu"}],"7":[{"p":1,"a":"تَتْبَعُهَا","t":"Follows it","tr":"tatbaʿuhā"},{"p":2,"a":"ٱلرَّادِفَةُ","t":"the subsequent","tr":"l-rādifatu"}],"8":[{"p":1,"a":"قُلُوبٌۭ","t":"Hearts","tr":"qulūbun"},{"p":2,"a":"يَوْمَئِذٍۢ","t":"that Day","tr":"yawma-idhin"},{"p":3,"a":"وَاجِفَةٌ","t":"will palpitate","tr":"wājifatun"}],"9":[{"p":1,"a":"أَبْصَـٰرُهَا","t":"Their eyes","tr":"abṣāruhā"},{"p":2,"a":"خَـٰشِعَةٌۭ","t":"humbled","tr":"khāshiʿatun"}],"10":[{"p":1,"a":"يَقُولُونَ","t":"They say","tr":"yaqūlūna"},{"p":2,"a":"أَءِنَّا","t":"Will we","tr":"a-innā"},{"p":3,"a":"لَمَرْدُودُونَ","t":"indeed be returned","tr":"lamardūdūna"},{"p":4,"a":"فِى","t":"to","tr":"fī"},{"p":5,"a":"ٱلْحَافِرَةِ","t":"the former state","tr":"l-ḥāfirati"}],"11":[{"p":1,"a":"أَءِذَا","t":"What! When","tr":"a-idhā"},{"p":2,"a":"كُنَّا","t":"we are","tr":"kunnā"},{"p":3,"a":"عِظَـٰمًۭا","t":"bones","tr":"ʿiẓāman"},{"p":4,"a":"نَّخِرَةًۭ","t":"decayed","tr":"nakhiratan"}],"12":[{"p":1,"a":"قَالُوا۟","t":"They say","tr":"qālū"},{"p":2,"a":"تِلْكَ","t":"This","tr":"til'ka"},{"p":3,"a":"إِذًۭا","t":"then","tr":"idhan"},{"p