{"surah":81,"ayahs":{"1":[{"p":1,"a":"إِذَا","t":"When","tr":"idhā"},{"p":2,"a":"ٱلشَّمْسُ","t":"the sun","tr":"l-shamsu"},{"p":3,"a":"كُوِّرَتْ","t":"is wrapped up","tr":"kuwwirat"}],"2":[{"p":1,"a":"وَإِذَا","t":"And when","tr":"wa-idhā"},{"p":2,"a":"ٱلنُّجُومُ","t":"the stars","tr":"l-nujūmu"},{"p":3,"a":"ٱنكَدَرَتْ","t":"fall, losing their luster","tr":"inkadarat"}],"3":[{"p":1,"a":"وَإِذَا","t":"And when","tr":"wa-idhā"},{"p":2,"a":"ٱلْجِبَالُ","t":"the mountains","tr":"l-jibālu"},{"p":3,"a":"سُيِّرَتْ","t":"are moved away","tr":"suyyirat"}],"4":[{"p":1,"a":"وَإِذَا","t":"And when","tr":"wa-idhā"},{"p":2,"a":"ٱلْعِشَارُ","t":"the full-term she-camels","tr":"l-ʿishāru"},{"p":3,"a":"عُطِّلَتْ","t":"(are) left untended","tr":"ʿuṭṭilat"}],"5":[{"p":1,"a":"وَإِذَا","t":"And when","tr":"wa-idhā"},{"p":2,"a":"ٱلْوُحُوشُ","t":"the wild beasts","tr":"l-wuḥūshu"},{"p":3,"a":"حُشِرَتْ","t":"are gathered","tr":"ḥushirat"}],"6":[{"p":1,"a":"وَإِذَا","t":"And when","tr":"wa-idhā"},{"p":2,"a":"ٱلْبِحَارُ","t":"the seas","tr":"l-biḥāru"},{"p":3,"a":"سُجِّرَتْ","t":"are made to overflow","tr":"sujjirat"}],"7":[{"p":1,"a":"وَإِذَا","t":"And when","tr":"wa-idhā"},{"p":2,"a":"ٱلنُّفُوسُ","t":"the souls","tr":"l-nufūsu"},{"p":3,"a":"زُوِّجَتْ","t":"are paired","tr":"zuwwijat"}],"8":[{"p":1,"a":"وَإِذَا","t":"And when","tr":"wa-idhā"},{"p":2,"a":"ٱلْمَوْءُۥدَةُ","t":"the female infant buried alive","tr":"l-mawūdatu"},{"p":3,"a":"سُئِلَتْ","t":"is asked","tr":"su-ilat"}],"9":[{"p":1,"a":"بِأَىِّ","t":"For what","tr":"bi-ayyi"},{"p":2,"a":"ذَنۢبٍۢ","t":"sin","tr":"dhanbin"},{"p":3,"a":"قُتِلَتْ","t":"she was killed","tr":"qutilat"}],"10":[{"p":1,"a":"وَإِذَا","t":"And when","tr":"wa-idhā"},{"p":2,"a":"ٱلصُّحُفُ","t":"the pages","tr":"l-ṣuḥufu"},{"p":3,"a":"نُشِرَتْ","t":"are laid open","tr":"nushirat"}],"11":[{"p":1,"a":"وَإِذَا","t":"And when","tr":"wa-idhā"},{"p":2,"a":"ٱلسَّمَآءُ","t":"the sky","tr":"l-samāu"},{"p":3,"a":"كُشِطَتْ","t":"is stripped away","tr":"kushiṭat"}],"12":[{"p":1,"a":"وَإِذَا","t":"And when","tr":"wa-idhā"},{"p":2,"a":"ٱلْجَحِيمُ","t":"the Hellfire","tr":"l-jaḥīmu"},{"p":3,"a":"سُعِّرَتْ","t":"is set ablaze","tr":"suʿʿirat"}],"13":[{"p":1,"a":"وَإِذَا","t":"And when","tr":"wa-idhā"},{"p":2,"a":"ٱلْجَنَّةُ","t":"Paradise","tr":"l-janatu"},{"p":3,"a":"أُزْلِفَتْ","t":"is brought near","tr":"uz'lifat"}],"14":[{"p":1,"a":"عَلِمَتْ","t":"Will know","tr":"ʿalimat"},{"p":2,"a":"نَفْسٌۭ","t":"a soul","tr":"nafsun"},{"p":3,"a":"مَّآ","t":"what","tr":"mā"},{"p":4,"a":"أَحْضَرَتْ","t":"it has brought","tr":"aḥḍarat"}],"15":[{"p":1,"a":"فَلَآ","t":"But nay","tr":"falā"},{"p":2,"a":"أُقْسِمُ","t":"I swear","tr":"uq'simu"},{"p":3,"a":"بِٱلْخُنَّسِ","t":"by the retreating planets","tr":"bil-khunasi"}],"16":[{"p":1,"a":"ٱلْجَوَارِ","t":"Those that run","tr":"al-jawāri"},{"p":2,"a":"ٱلْكُنَّسِ","t":"(and) disappear","tr":"l-kunasi"}],"17":[{"p":1,"a":"وَٱلَّيْلِ","t":"And the night","tr":"wa-al-layli"},{"p":2,"a":"إِذَا","t":"when","tr":"idhā"},{"p":3,"a":"عَسْعَسَ","t":"it departs","tr":"ʿasʿasa"}],"18":[{"p":1,"a":"وَٱلصُّبْحِ","t":"And the dawn","tr":"wal-ṣub'ḥi"},{"p":2,"a":"إِذَا","t":"when","tr":"idhā"},{"p":3,"a":"تَنَفَّسَ","t":"it breathes","tr":"tanaffasa"}],"19":[{"p":1,"a":"إِنَّهُۥ","t":"Indeed, it","tr":"innahu"},{"p":2,"a":"لَقَوْلُ","t":"(is) surely a word","tr":"laqawlu"},{"p":3,"a":"رَسُولٍۢ","t":"(of) a Messenger","tr":"rasūlin"},{"p":4,"a":"كَرِيمٍۢ","t":"noble","tr":"karīmin"}],"20":[{"p":1,"a":"ذِى","t":"Possessor of","tr":"dhī"},{"p":2,"a":"قُوَّةٍ","t":"power","tr":"quwwatin"},{"p":3,"a":"عِندَ","t":"with","tr":"ʿinda"},{"p":4,"a":"ذِى","t":"(the) Owner of","tr":"dhī"},{"p":5,"a":"ٱلْعَرْشِ","t":"the Throne","tr":"l-ʿarshi"},{"p":6,"a":"مَكِينٍۢ","t":"secure","tr":"makīnin"}],"21":[{"p":1,"a":"مُّطَاعٍۢ","t":"One to be obeyed","tr":"muṭāʿin"},{"p":2,"a":"ثَمَّ","t":"and","tr":"thamma"},{"p":3,"a":"أَمِينٍۢ","t":"trustworthy","tr":"amīnin"}],"22":[{"p":1,"a":"وَمَا","t":"And not","tr":"wamā"},{"p":2,"a":"صَاحِبُكُم","t":"(is) your companion","tr":"ṣāḥibukum"},{"p":3,"a":"بِمَجْنُونٍۢ","t":"mad","tr":"bimajnūnin"}],"23":[{"p":1,"a":"وَلَقَدْ","t":"And certainly","tr":"walaqad"},{"p":2,"a":"رَءَاهُ","t":"he saw him","tr":"raāhu"},{"p":3,"a":"بِٱلْأُفُقِ","t":"in the horizon","tr":"bil-ufuqi"},{"p":4,"a":"ٱلْمُبِينِ","t":"the clear","tr":"l-mubīni"}],"24":[{"p":1,"a":"وَمَا","t":"And not","tr":"wamā"},{"p":2,"a":"هُوَ","t":"he (is)","tr":"huwa"},{"p":3,"a":"عَلَى","t":"on","tr":"ʿalā"},{"p":4,"a":"ٱلْغَيْبِ","t":"the unseen","tr":"l-ghaybi"},{"p":5,"a":"بِضَنِينٍۢ","t":"a withholder","tr":"biḍanīnin"}],"25":[{"p":1,"a":"وَمَا","t":"And not","tr":"wamā"},{"p":2,"a":"هُوَ","t":"it","tr":"huwa"},{"p":3,"a":"بِقَوْلِ","t":"(is the) word","tr":"biqawli"},{"p":4,"a":"شَيْطَـٰنٍۢ","t":"(of) Shaitaan","tr":"shayṭānin"},{"p":5,"a":"رَّجِيمٍۢ","t":"accursed","tr":"rajīmin"}],"26":[{"p":1,"a":"فَأَيْنَ","t":"So where","tr":"fa-ayna"},{"p":2,"a":"تَذْهَبُونَ","t":"are you going","tr":"tadhhabūna"}],"27":[{"p":1,"a":"إِنْ","t":"Not","tr":"in"},{"p":2,"a":"هُوَ","t":"it","tr":"huwa"},{"p":3,"a":"إِلَّا","t":"(is) except","tr":"illā"},{"p":4,"a":"ذِكْرٌۭ","t":"a reminder","tr":"dhik'run"},{"p":5,"a":"لِّلْعَـٰلَمِينَ","t":"to the worlds","tr":"lil'ʿālamīna"}],"28":[{"p":1,"a":"لِمَن","t":"For whoever","tr":"liman"},{"p":2,"a":"شَآءَ","t":"wills","tr":"shāa"},{"p":3,"a":"مِنكُمْ","t":"among you","tr":"minkum"},{"p":4,"a":"أَن","t":"to","tr":"an"},{"p":5,"a":"يَسْتَقِيمَ","t":"take a straight way","tr":"yastaqīma"}],"29":[{"p":1,"a":"وَمَا","t":"And not","tr":"wamā"},{"p":2,"a":"تَشَآءُونَ","t":"you will","tr":"tashāūna"},{"p":3,"a":"إِلَّآ","t":"except","tr":"illā"},{"p":4,"a":"أَن","t":"that","tr":"an"},{"p":5,"a":"يَشَآءَ","t":"wills","tr":"yashāa"},{"p":6,"a":"ٱللَّهُ","t":"Allah","tr":"l-lahu"},{"p":7,"a":"رَبُّ","t":"Lord","tr":"rabbu"},{"p":8,"a":"ٱلْعَـٰلَمِينَ","t":"(of) the worlds","tr":"l-ʿālamīna"}]}}