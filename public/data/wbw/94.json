{"surah":94,"ayahs":{"1":[{"p":1,"a":"أَلَمْ","t":"Have not","tr":"alam"},{"p":2,"a":"نَشْرَحْ","t":"We expanded","tr":"nashraḥ"},{"p":3,"a":"لَكَ","t":"for you","tr":"laka"},{"p":4,"a":"صَدْرَكَ","t":"your breast","tr":"ṣadraka"}],"2":[{"p":1,"a":"وَوَضَعْنَا","t":"And We removed","tr":"wawaḍaʿnā"},{"p":2,"a":"عَنكَ","t":"from you","tr":"ʿanka"},{"p":3,"a":"وِزْرَكَ","t":"your burden","tr":"wiz'raka"}],"3":[{"p":1,"a":"ٱلَّذِىٓ","t":"Which","tr":"alladhī"},{"p":2,"a":"أَنقَضَ","t":"weighed upon","tr":"anqaḍa"},{"p":3,"a":"ظَهْرَكَ","t":"your back","tr":"ẓahraka"}],"4":[{"p":1,"a":"وَرَفَعْنَا","t":"And We raised high","tr":"warafaʿnā"},{"p":2,"a":"لَكَ","t":"for you","tr":"laka"},{"p":3,"a":"ذِكْرَكَ","t":"your reputation","tr":"dhik'raka"}],"5":[{"p":1,"a":"فَإِنَّ","t":"So indeed","tr":"fa-inna"},{"p":2,"a":"مَعَ","t":"with","tr":"maʿa"},{"p":3,"a":"ٱلْعُسْرِ","t":"the hardship","tr":"l-ʿus'ri"},{"p":4,"a":"يُسْرًا","t":"(is) ease","tr":"yus'ran"}],"6":[{"p":1,"a":"إِنَّ","t":"Indeed","tr":"inna"},{"p":2,"a":"مَعَ","t":"with","tr":"maʿa"},{"p":3,"a":"ٱلْعُسْرِ","t":"the hardship","tr":"l-ʿus'ri"},{"p":4,"a":"يُسْرًۭا","t":"(is) ease","tr":"yus'ran"}],"7":[{"p":1,"a":"فَإِذَا","t":"So when","tr":"fa-idhā"},{"p":2,"a":"فَرَغْتَ","t":"you have finished","tr":"faraghta"},{"p":3,"a":"فَٱنصَبْ","t":"then labor hard","tr":"fa-inṣab"}],"8":[{"p":1,"a":"وَإِلَىٰ","t":"And to","tr":"wa-ilā"},{"p":2,"a":"رَبِّكَ","t":"your Lord","tr":"rabbika"},{"p":3,"a":"فَٱرْغَب","t":"turn your attention","tr":"fa-ir'ghab"}]}}