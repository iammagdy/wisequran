ilā"},{"p":4,"a":"أَهْلِهِمُ","t":"their people","tr":"ahlihimu"},{"p":5,"a":"ٱنقَلَبُوا۟","t":"they would return","tr":"inqalabū"},{"p":6,"a":"فَكِهِينَ","t":"jesting","tr":"fakihīna"}],"32":[{"p":1,"a":"وَإِذَا","t":"And when","tr":"wa-idhā"},{"p":2,"a":"رَأَوْهُمْ","t":"they saw them","tr":"ra-awhum"},{"p":3,"a":"قَالُوٓا۟","t":"they said","tr":"qālū"},{"p":4,"a":"إِنَّ","t":"Indeed","tr":"inna"},{"p":5,"a":"هَـٰٓؤُلَآءِ","t":"these","tr":"hāulāi"},{"p":6,"a":"لَضَآلُّونَ","t":"surely have gone astray","tr":"laḍāllūna"}],"33":[{"p":1,"a":"وَمَآ","t":"But not","tr":"wamā"},{"p":2,"a":"أُرْسِلُوا۟","t":"they had been sent","tr":"ur'silū"},{"p":3,"a":"عَلَيْهِمْ","t":"over them","tr":"ʿalayhim"},{"p":4,"a":"حَـٰفِظِينَ","t":"(as) guardians","tr":"ḥāfiẓīna"}],"34":[{"p":1,"a":"فَٱلْيَوْمَ","t":"So today","tr":"fal-yawma"},{"p":2,"a":"ٱلَّذِينَ","t":"those who","tr":"alladhīna"},{"p":3,"a":"ءَامَنُوا۟","t":"believed ","tr":"āmanū"},{"p":4,"a":"مِنَ","t":"at","tr":"mina"},{"p":5,"a":"ٱلْكُفَّارِ","t":"the disbelievers","tr":"l-kufāri"},{"p":6,"a":"يَضْحَكُونَ","t":"they will laugh","tr":"yaḍḥakūna"}],"35":[{"p":1,"a":"عَلَى","t":"On","tr":"ʿalā"},{"p":2,"a":"ٱلْأَرَآئِكِ","t":"the thrones","tr":"l-arāiki"},{"p":3,"a":"يَنظُرُونَ","t":"observing","tr":"yanẓurūna"}],"36":[{"p":1,"a":"هَلْ","t":"Have (not)","tr":"hal"},{"p":2,"a":"ثُوِّبَ","t":"been rewarded","tr":"thuwwiba"},{"p":3,"a":"ٱلْكُفَّارُ","t":"the disbelievers","tr":"l-kufāru"},{"p":4,"a":"مَا","t":"(for) what","tr":"mā"},{"p":5,"a":"كَانُوا۟","t":"they used to","tr":"kānū"},{"p":6,"a":"يَفْعَلُونَ","t":"do","tr":"yafʿalūna"}]}}