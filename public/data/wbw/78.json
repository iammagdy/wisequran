{"surah":78,"ayahs":{"1":[{"p":1,"a":"عَمَّ","t":"About what","tr":"ʿamma"},{"p":2,"a":"يَتَسَآءَلُونَ","t":"are they asking one another","tr":"yatasāalūna"}],"2":[{"p":1,"a":"عَنِ","t":"About","tr":"ʿani"},{"p":2,"a":"ٱلنَّبَإِ","t":"the News","tr":"l-naba-i"},{"p":3,"a":"ٱلْعَظِيمِ","t":"the Great","tr":"l-ʿaẓīmi"}],"3":[{"p":1,"a":"ٱلَّذِى","t":"(About) which","tr":"alladhī"},{"p":2,"a":"هُمْ","t":"they","tr":"hum"},{"p":3,"a":"فِيهِ","t":"(are) concerning it","tr":"fīhi"},{"p":4,"a":"مُخْتَلِفُونَ","t":"(in) disagreement","tr":"mukh'talifūna"}],"4":[{"p":1,"a":"كَلَّا","t":"Nay","tr":"kallā"},{"p":2,"a":"سَيَعْلَمُونَ","t":"(soon) they will know","tr":"sayaʿlamūna"}],"5":[{"p":1,"a":"ثُمَّ","t":"Then","tr":"thumma"},{"p":2,"a":"كَلَّا","t":"Nay","tr":"kallā"},{"p":3,"a":"سَيَعْلَمُونَ","t":"(soon) they will know","tr":"sayaʿlamūna"}],"6":[{"p":1,"a":"أَلَمْ","t":"Have not","tr":"alam"},{"p":2,"a":"نَجْعَلِ","t":"We made","tr":"najʿali"},{"p":3,"a":"ٱلْأَرْضَ","t":"the earth","tr":"l-arḍa"},{"p":4,"a":"مِهَـٰدًۭا","t":"a resting place","tr":"mihādan"}],"7":[{"p":1,"a":"وَٱلْجِبَالَ","t":"And the mountains","tr":"wal-jibāla"},{"p":2,"a":"أَوْتَادًۭا","t":"(as) pegs","tr":"awtādan"}],"8":[{"p":1,"a":"وَخَلَقْنَـٰكُمْ","t":"And We created you","tr":"wakhalaqnākum"},{"p":2,"a":"أَزْوَٰجًۭا","t":"(in) pairs","tr":"azwājan"}],"9":[{"p":1,"a":"وَجَعَلْنَا","t":"And We made","tr":"wajaʿalnā"},{"p":2,"a":"نَوْمَكُمْ","t":"your sleep","tr":"nawmakum"},{"p":3,"a":"سُبَاتًۭا","t":"(for) rest","tr":"subātan"}],"10":[{"p":1,"a":"وَجَعَلْنَا","t":"And We made","tr":"wajaʿalnā"},{"p":2,"a":"ٱلَّيْلَ","t":"the night","tr":"al-layla"},{"p":3,"a":"لِبَاسًۭا","t":"(as) covering","tr":"libāsan"}],"11":[{"p":1,"a":"وَجَعَلْنَا","t":"And We made","tr":"wajaʿalnā"},{"p":2,"a":"ٱلنَّهَارَ","t":"the day","tr":"l-nahāra"},{"p":3,"a":"مَعَاشًۭا","t":"(for) livelihood","tr":"maʿāshan"}],"12":[{"p":1,"a":"وَبَنَيْنَا","t":"And We constructed","tr":"wabanaynā"},{"p":2,"a":"فَوْقَكُمْ","t":"ov