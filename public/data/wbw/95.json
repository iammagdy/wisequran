{"surah":95,"ayahs":{"1":[{"p":1,"a":"وَٱلتِّينِ","t":"By the fig","tr":"wal-tīni"},{"p":2,"a":"وَٱلزَّيْتُونِ","t":"and the olive","tr":"wal-zaytūni"}],"2":[{"p":1,"a":"وَطُورِ","t":"And (the) Mount","tr":"waṭūri"},{"p":2,"a":"سِينِينَ","t":"Sinai","tr":"sīnīna"}],"3":[{"p":1,"a":"وَهَـٰذَا","t":"And this","tr":"wahādhā"},{"p":2,"a":"ٱلْبَلَدِ","t":"[the] city","tr":"l-baladi"},{"p":3,"a":"ٱلْأَمِينِ","t":"[the] secure","tr":"l-amīni"}],"4":[{"p":1,"a":"لَقَدْ","t":"Indeed","tr":"laqad"},{"p":2,"a":"خَلَقْنَا","t":"We created","tr":"khalaqnā"},{"p":3,"a":"ٱلْإِنسَـٰنَ","t":"man","tr":"l-insāna"},{"p":4,"a":"فِىٓ","t":"in","tr":"fī"},{"p":5,"a":"أَحْسَنِ","t":"(the) best","tr":"aḥsani"},{"p":6,"a":"تَقْوِيمٍۢ","t":"mould","tr":"taqwīmin"}],"5":[{"p":1,"a":"ثُمَّ","t":"Then","tr":"thumma"},{"p":2,"a":"رَدَدْنَـٰهُ","t":"We returned him","tr":"radadnāhu"},{"p":3,"a":"أَسْفَلَ","t":"(to the) lowest","tr":"asfala"},{"p":4,"a":"سَـٰفِلِينَ","t":"(of the) low","tr":"sāfilīna"}],"6":[{"p":1,"a":"إِلَّا","t":"Except","tr":"illā"},{"p":2,"a":"ٱلَّذِينَ","t":"those who","tr":"alladhīna"},{"p":3,"a":"ءَامَنُوا۟","t":"believe","tr":"āmanū"},{"p":4,"a":"وَعَمِلُوا۟","t":"and do","tr":"waʿamilū"},{"p":5,"a":"ٱلصَّـٰلِحَـٰتِ","t":"righteous deeds","tr":"l-ṣāliḥāti"},{"p":6,"a":"فَلَهُمْ","t":"then for them","tr":"falahum"},{"p":7,"a":"أَجْرٌ","t":"(is a) reward","tr":"ajrun"},{"p":8,"a":"غَيْرُ","t":"never","tr":"ghayru"},{"p":9,"a":"مَمْنُونٍۢ","t":"ending","tr":"mamnūnin"}],"7":[{"p":1,"a":"فَمَا","t":"Then what","tr":"famā"},{"p":2,"a":"يُكَذِّبُكَ","t":"causes you to deny","tr":"yukadhibuka"},{"p":3,"a":"بَعْدُ","t":"after (this)","tr":"baʿdu"},{"p":4,"a":"بِٱلدِّينِ","t":"the judgment","tr":"bil-dīni"}],"8":[{"p":1,"a":"أَلَيْسَ","t":"Is not","tr":"alaysa"},{"p":2,"a":"ٱللَّهُ","t":"Allah","tr":"l-lahu"},{"p":3,"a":"بِأَحْكَمِ","t":"(the) Most Just","tr":"bi-aḥkami"},{"p":4,"a":"ٱلْحَـٰكِمِينَ","t":"(of) the Judges","tr":"l-ḥākimīna"}]}}