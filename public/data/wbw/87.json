{"surah":87,"ayahs":{"1":[{"p":1,"a":"سَبِّحِ","t":"Glorify","tr":"sabbiḥi"},{"p":2,"a":"ٱسْمَ","t":"(the) name","tr":"is'ma"},{"p":3,"a":"رَبِّكَ","t":"(of) your Lord","tr":"rabbika"},{"p":4,"a":"ٱلْأَعْلَى","t":"the Most High","tr":"l-aʿlā"}],"2":[{"p":1,"a":"ٱلَّذِى","t":"The One Who","tr":"alladhī"},{"p":2,"a":"خَلَقَ","t":"created","tr":"khalaqa"},{"p":3,"a":"فَسَوَّىٰ","t":"then proportioned","tr":"fasawwā"}],"3":[{"p":1,"a":"وَٱلَّذِى","t":"And the One Who","tr":"wa-alladhī"},{"p":2,"a":"قَدَّرَ","t":"measured","tr":"qaddara"},{"p":3,"a":"فَهَدَىٰ","t":"then guided","tr":"fahadā"}],"4":[{"p":1,"a":"وَٱلَّذِىٓ","t":"And the One Who","tr":"wa-alladhī"},{"p":2,"a":"أَخْرَجَ","t":"brings forth","tr":"akhraja"},{"p":3,"a":"ٱلْمَرْعَىٰ","t":"the pasture","tr":"l-marʿā"}],"5":[{"p":1,"a":"فَجَعَلَهُۥ","t":"And then makes it","tr":"fajaʿalahu"},{"p":2,"a":"غُثَآءً","t":"stubble","tr":"ghuthāan"},{"p":3,"a":"أَحْوَىٰ","t":"dark","tr":"aḥwā"}],"6":[{"p":1,"a":"سَنُقْرِئُكَ","t":"We will make you recite","tr":"sanuq'ri-uka"},{"p":2,"a":"فَلَا","t":"so not","tr":"falā"},{"p":3,"a":"تَنسَىٰٓ","t":"you will forget","tr":"tansā"}],"7":[{"p":1,"a":"إِلَّا","t":"Except","tr":"illā"},{"p":2,"a":"مَا","t":"what","tr":"mā"},{"p":3,"a":"شَآءَ","t":"wills","tr":"shāa"},{"p":4,"a":"ٱللَّهُ ۚ","t":"Allah","tr":"l-lahu"},{"p":5,"a":"إِنَّهُۥ","t":"Indeed, He","tr":"innahu"},{"p":6,"a":"يَعْلَمُ","t":"knows","tr":"yaʿlamu"},{"p":7,"a":"ٱلْجَهْرَ","t":"the manifest","tr":"l-jahra"},{"p":8,"a":"وَمَا","t":"and what","tr":"wamā"},{"p":9,"a":"يَخْفَىٰ","t":"is hidden","tr":"yakhfā"}],"8":[{"p":1,"a":"وَنُيَسِّرُكَ","t":"And We will ease you","tr":"wanuyassiruka"},{"p":2,"a":"لِلْيُسْرَىٰ","t":"to the ease","tr":"lil'yus'rā"}],"9":[{"p":1,"a":"فَذَكِّرْ","t":"So remind","tr":"fadhakkir"},{"p":2,"a":"إِن","t":"if","tr":"in"},{"p":3,"a":"نَّفَعَتِ","t":"benefits","tr":"nafaʿati"},{"p":4,"a":"ٱلذِّكْرَىٰ","t":"the reminder","tr":"l-dhik'rā"}],"10":[{"p":1,"a":"سَيَذَّكَّرُ","t":"He will pay