# SPA fallback: serve index.html for any path that doesn't match a real file
# or directory, so React Router can handle client-side routes (/devkit, /sleep,
# /signin, /auth/callback, etc.) on direct URL access and refresh.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't rewrite the service worker or manifest — they must serve as-is.
  RewriteRule ^(sw\.js|sw\.js\.map|manifest\.json|registerSW\.js)$ - [L]

  # Don't rewrite real files or directories.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else falls back to index.html (200, not 301) so the SPA boots.
  RewriteRule . /index.html [L]
</IfModule>

# Make sure the service worker is never cached at the edge — it must re-check
# on every visit so updates roll out quickly.
<IfModule mod_headers.c>
  <FilesMatch "^(sw\.js|registerSW\.js)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
